    {
      "name": "PATCH2 with checksum",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const cryptoJS = require('crypto-js');\r",
              "const bodyContent = pm.request.body.raw;\r",
              "\r",
              "if (bodyContent) {\r",
              "    // 1. caculate sha1\r",
              "    const hash = cryptoJS.SHA1(bodyContent).toString(); \r",
              "    // 2. set Upload-Checksum Header\r",
              "    pm.request.headers.add({\r",
              "        key: 'Checksum',\r",
              "        value: `sha1 ${hash}`\r",
              "    });\r",
              "    pm.request.headers.add({\r",
              "        key: 'Checksum-Algorithm',\r",
              "        value: 'sha1'\r",
              "    });\r",
              "    console.log(\"Checksum: \" + hash);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Successful PATCH request, upload offset should be updated\", () => {\r",
              "    pm.response.to.have.status(204);\r",
              "    const newOffset = Number(pm.response.headers.get(\"Upload-Offset\"));\r",
              "    pm.expect(newOffset).to.be.greaterThan(0); // Assuming offset should be greater than 0 after a successful upload\r",
              "    pm.collectionVariables.set(\"offset\", newOffset); // Store the new offset in a collection variable for future use\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
