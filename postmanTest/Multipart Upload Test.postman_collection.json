  "item": [
    {
      "name": "POST /uploadfiles",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Successful POST request, create a new file id\", () => {\r",
              "    pm.response.to.have.status(201);\r",
              "    const location = pm.response.headers.get(\"Location\");\r",
              "    const fileId = location.split(\"/\").pop();\r",
              "    console.log(fileId);\r",
              "    pm.collectionVariables.set(\"fileId\", fileId);\r",
              "    pm.collectionVariables.set(\"offset\", 0)\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Upload-Metadata",
            "value": "filename testfile.text, filetype text/plain",
            "type": "text"
          },
          {
            "key": "Upload-Length",
            "value": "60",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": ""
        },
        "url": {
          "raw": "http://{{host}}:{{port}}/uploadfiles",
          "protocol": "http",
          "host": [
            "{{host}}"
          ],
          "port": "{{port}}",
          "path": [
            "uploadfiles"
          ]
        }
      },
      "response": []
    },
    {
      "name": "PATCH1 /uploadfiles/{fileId}",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Successful PATCH request, upload offset should be updated\", () => {\r",
              "    pm.response.to.have.status(204);\r",
              "    const newOffset = Number(pm.response.headers.get(\"Upload-Offset\"));\r",
              "    pm.expect(newOffset).to.greaterThan(0); // Assuming offset should be greater than 0 after a successful upload\r",
              "    pm.collectionVariables.set(\"offset\", newOffset); // Store the new offset in a collection variable for future use\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
